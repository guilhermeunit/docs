{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Unit",
  "colors": {
    "primary": "#0CCC33",
    "light": "#2FD45C",
    "dark": "#0AAE2B"
  },
  "favicon": "/favicon.png",
  "fonts": {
    "family": "Poppins"
  },
  "navigation": {
    "pages": [
      "index",
      "changelog"
    ]
  },
  "redirects": [
    {
      "source": "/api-parceiros",
      "destination": "/"
    },
    {
      "source": "/quickstart",
      "destination": "/"
    }
  ],
  "logo": {
    "light": "/logo/unit-horizontal.png",
    "dark": "/logo/unit-horizontal-white.png"
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  }
}
